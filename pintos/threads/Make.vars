# -*- makefile -*-

# threads 커널 이미지를 만들 때 쓰는 빌드 설정이다.
# 이 파일은 BIOS가 읽어 들이는 코드가 아니며, 에뮬레이터의 CPU에서 실행되지도 않는다.
# 첫 번째 섹터에 loader.S가 들어가는 디스크 이미지를 만들 때, 어떤 PintOS 하위
# 디렉터리와 테스트를 커널에 함께 컴파일할지만 make에 알려 준다.
os.dsk: DEFINES =
KERNEL_SUBDIRS = threads devices lib lib/kernel $(TEST_SUBDIRS)
TEST_SUBDIRS = tests/threads tests/threads/mlfqs
GRADING_FILE = $(SRCDIR)/tests/threads/Grading
