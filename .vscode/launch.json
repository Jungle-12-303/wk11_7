{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "테스트 디버거",
            "type": "cppdbg",
            "request": "launch",
            "preLaunchTask": "Pintos: Start debug test GDB server",
            "postDebugTask": "Pintos: Stop debug test GDB server",
            "program": "${workspaceFolder}/pintos/vm/build/kernel.o",
            "cwd": "${workspaceFolder}/pintos/vm/build",
            "miDebuggerServerAddress": "localhost:1234",
            "miDebuggerPath": "/usr/bin/gdb",
            "MIMode": "gdb",
            "stopAtEntry": false,
            "launchCompleteCommand": "exec-continue",
            "sourceFileMap": {
                "/workspaces/SW_AI-W11-pintos": "${workspaceFolder}",
                "/workspaces/wk11_7": "${workspaceFolder}",
                "../../": "${workspaceFolder}/pintos"
            },
            "setupCommands": [
                {
                    "text": "-enable-pretty-printing",
                    "ignoreFailures": true
                },
                {
                    "text": "source ${workspaceFolder}/.vscode/pintos-debug.gdb",
                    "ignoreFailures": true
                },
                {
                    "text": "rbreak ^debug_test_",
                    "ignoreFailures": false
                }
            ]
        },
        {
            "name": "VM GDB 서버에 연결",
