{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Pintos: Build userprog",
      "type": "shell",
      "command": "source \"${workspaceFolder}/pintos/activate\" && make -C \"${workspaceFolder}/pintos/userprog\"",
      "options": {
        "shell": {
          "executable": "/bin/bash",
          "args": [
            "-lc"
          ]
        }
      },
      "group": {
        "kind": "build",
        "isDefault": false
      },
      "problemMatcher": "$gcc"
    },
    {
      "label": "Pintos: Build threads",
      "type": "shell",
      "command": "source \"${workspaceFolder}/pintos/activate\" && make -C \"${workspaceFolder}/pintos/threads\"",
      "options": {
        "shell": {
          "executable": "/bin/bash",
          "args": [
            "-lc"
          ]
        }
      },
      "group": "build",
      "problemMatcher": "$gcc"
    },
    {
      "label": "Pintos: Build vm",
      "type": "shell",
      "command": "source \"${workspaceFolder}/pintos/activate\" && make -C \"${workspaceFolder}/pintos/vm\"",
      "options": {
        "shell": {
          "executable": "/bin/bash",
          "args": [
            "-lc"
          ]
        }
      },
      "group": "build",
      "problemMatcher": "$gcc"
    },
    {
      "label": "Pintos: Check selected test",
      "type": "shell",
      "command": "source \"${workspaceFolder}/pintos/activate\" && make -C \"${workspaceFolder}/pintos/${input:pintosProject}\" && make -C \"${workspaceFolder}/pintos/${input:pintosProject}/build\" check TESTS=\"${input:pintosTestPath}\"",
      "options": {
        "shell": {
          "executable": "/bin/bash",
          "args": [
            "-lc"
          ]
        }
      },
      "group": "test",
      "problemMatcher": "$gcc"
    },
    {
      "label": "Pintos: Run threads test",
      "type": "shell",
      "command": "source \"${workspaceFolder}/pintos/activate\" && make -C \"${workspaceFolder}/pintos/threads\" && cd \"${workspaceFolder}/pintos/threads/build\" && pintos -- -q run \"${input:threadsTestName}\"",
      "options": {
        "shell": {
          "executable": "/bin/bash",
          "args": [
            "-lc"
          ]
        }
      },
      "group": "test",
      "problemMatcher": []
    },
    {
      "label": "Pintos: Start threads GDB server",
      "type": "shell",
      "command": "source \"${workspaceFolder}/pintos/activate\" && make -C \"${workspaceFolder}/pintos/threads\" && cd \"${workspaceFolder}/pintos/threads/build\" && pintos --gdb -- -q run \"${input:threadsTestName}\"",
      "options": {
        "shell": {
          "executable": "/bin/bash",
          "args": [
            "-lc"
          ]
        }
      },
      "isBackground": true,
      "problemMatcher": []
    },
    {
      "label": "Pintos: Start debug test GDB server",
      "type": "shell",
      "command": "source \"${workspaceFolder}/pintos/activate\" && make -C \"${workspaceFolder}\" test-debug-wait TEST=\"${input:debugTestName}\"",
      "options": {
        "shell": {
          "executable": "/bin/bash",
          "args": [
            "-lc"
          ]
        }
      },
      "isBackground": true,
      "problemMatcher": {
        "owner": "pintos-debug-test",
        "pattern": {
          "regexp": "^(.*)$",
          "message": 1
        },
        "background": {
          "activeOnStart": true,
          "beginsPattern": "^.*\\[debug-start\\].*$",
          "endsPattern": "^.*\\[debug-ready\\].*$"
        }
      }
    },
    {
      "label": "Pintos: Stop debug test GDB server",
      "type": "shell",
      "command": "pkill -TERM -f 'qemu-system-x86_64.*-s -S' 2>/dev/null || true; pkill -TERM -f 'run-debug-tests.py.*--debug-mode wait' 2>/dev/null || true",
      "options": {
        "shell": {
          "executable": "/bin/bash",
          "args": [
            "-lc"
          ]
        }
      },
      "problemMatcher": []
    },
    {
      "label": "Pintos: Run debug test",
      "type": "shell",
      "command": "source \"${workspaceFolder}/pintos/activate\" && make -C \"${workspaceFolder}\" test TEST=\"${input:debugTestName}\"",
      "options": {
        "shell": {
          "executable": "/bin/bash",
          "args": [
            "-lc"
          ]
        }
      },
      "group": "test",
      "problemMatcher": "$gcc"
    },
    {
      "label": "Pintos: Clean selected project",
      "type": "shell",
      "command": "make -C \"${workspaceFolder}/pintos/${input:pintosProject}\" clean",
      "options": {
        "shell": {
          "executable": "/bin/bash",
          "args": [
            "-lc"
          ]
        }
      },
      "problemMatcher": []
    }
  ],
  "inputs": [
    {
      "id": "pintosProject",
      "type": "pickString",
      "description": "Pintos project",
      "options": [
        "userprog",
        "threads",
        "vm",
        "filesys"
      ],
      "default": "userprog"
    },
    {
      "id": "pintosTestPath",
      "type": "promptString",
      "description": "Test path for make check",
      "default": "tests/userprog/args-none"
    },
    {
      "id": "threadsTestName",
      "type": "promptString",
      "description": "Thread test name",
      "default": "alarm-multiple"
    },
    {
      "id": "debugTestName",
      "type": "promptString",
      "description": "Debug test name or file stem",
      "default": "smoke"
    }
  ]
}
