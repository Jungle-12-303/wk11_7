{
    "C_Cpp.formatting": "clangFormat",
    "C_Cpp.clang_format_style": "file",
    "C_Cpp.clang_format_fallbackStyle": "GNU",
    "C_Cpp.clang_format_sortIncludes": false,
    "C_Cpp.default.cStandard": "gnu17",
    "C_Cpp.default.compilerPath": "/usr/bin/gcc",
    "C_Cpp.default.intelliSenseMode": "linux-gcc-x64",
    "C_Cpp.default.defines": [
        "USERPROG",
        "VM",
        "FILESYS"
    ],
    "C_Cpp.default.includePath": [
        "${workspaceFolder}/pintos",
        "${workspaceFolder}/pintos/include/**",
        "${workspaceFolder}/pintos/include/lib/**",
        "${workspaceFolder}/pintos/include/lib/kernel/**",
        "${workspaceFolder}/pintos/lib/**"
    ],
    "C_Cpp.debugShortcut": false,
    "editor.formatOnSave": true,
    "editor.formatOnPaste": true,
    "editor.formatOnType": true,
    "[c]": {
      "editor.wordBasedSuggestions": "off",
      "editor.semanticHighlighting.enabled": true,
      "editor.stickyScroll.defaultModel": "foldingProviderModel",
      "editor.suggest.insertMode": "replace",
      "editor.defaultFormatter": "ms-vscode.cpptools",
      "editor.tabSize": 4,
      "editor.insertSpaces": false,
      "editor.detectIndentation": false,
      "editor.formatOnSave": true
    },
    "[cpp]": {
      "editor.wordBasedSuggestions": "off",
      "editor.semanticHighlighting.enabled": true,
      "editor.stickyScroll.defaultModel": "foldingProviderModel",
      "editor.suggest.insertMode": "replace",
      "editor.defaultFormatter": "ms-vscode.cpptools",
      "editor.tabSize": 4,
      "editor.insertSpaces": false,
      "editor.detectIndentation": false,
      "editor.formatOnSave": true
    },
    "[makefile]": {
        "editor.formatOnSave": false,
        "editor.insertSpaces": false
    },
    "files.trimTrailingWhitespace": true,
    "files.insertFinalNewline": true,
    "files.trimFinalNewlines": true,
    "files.exclude": {
        "pintos/tools/debug-test/generated": true
    },
    "debug.showExceptionWidget": false,
    "makefile.makeDirectory": "${workspaceFolder}",
    "bookmarks.saveBookmarksInProject": false
}
